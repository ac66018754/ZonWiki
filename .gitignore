# ============================================================
# ZonWiki .gitignore
# 混合專案：筆記（Markdown/圖片）+ 後端（.NET 10）+ 前端（Next.js）
# 模式：blacklist（預設追蹤所有檔案，僅排除建置產物、密鑰、臨時檔）
# 注意：每條規則「自己一行」，不可在規則後接行內註解
#       （git 會把註解連同前面的空白當成 pattern 的一部分 → 整條失效）。
# ============================================================

# ------------------------------------------------------------
# OS / 編輯器臨時檔
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# ------------------------------------------------------------
# Claude Code 本機設定（含本機路徑/權限，不進版控）
# ------------------------------------------------------------
.claude/settings.local.json
# Claude Code 代理用的 git worktree（git 內部 plumbing，純本機；清除請用 git worktree remove）
.claude/worktrees/

# ------------------------------------------------------------
# .NET / C#
# ------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.pdb
*.cache
# C# language-server 快取（純建置產物）
*.lscache
*.coverage
*.coveragexml
*.cobertura.xml
TestResults/
coverage/
.dotnet/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
msbuild.binlog

# ------------------------------------------------------------
# Node / Next.js
# ------------------------------------------------------------
node_modules/
.next/
# Next.js 建置殘留變體（例如 .next.stale-0，可達 GB 級）
.next.stale-*/
out/
dist/
build/
.turbo/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.yarn/cache
.yarn/install-state.gz
next-env.d.ts

# ------------------------------------------------------------
# 密鑰 / 環境變數（絕對不要 commit）
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.pfx
*.pem
*.key
secrets.json
appsettings.*.Local.json
appsettings.Production.json

# ------------------------------------------------------------
# Docker volumes / runtime
# ------------------------------------------------------------
.docker/
postgres-data/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# 暫存 / 工具快取 / 測試輸出（不進版控）
# 每條規則自己一行（先前用行內註解導致整段失效，已修正）
# ------------------------------------------------------------
# SQLite 暫存（如 kaiwen 遷移用），DB 以 Postgres 為準
*.db
# 一次性暫存檔（曾夾帶 register.json 站長密碼等敏感檔）
tmp/
# Playwright MCP 工作階段輸出（可能很大）
.playwright-mcp/
# Playwright 驗證截圖（測試產物）
zonwiki-ui-tests/
# understand-anything 工具的知識圖快取（可重建）
.understand-anything/
# 本機封存／隔離區（清理時搬出的舊檔，不公開）
_archive/
# 本機專用維運腳本（含 VM 帳號 / Prod DB 連線通道等，不公開；本機自用）
scripts/local/

# ------------------------------------------------------------
# 內部營運文件（含 VM 帳號 / 專案 ID / 網域 / IAP 等，不公開）
# ------------------------------------------------------------
docs/deployment/

# ------------------------------------------------------------
# 備註
# ------------------------------------------------------------
# docs/notes-seed/ 下的 .md 為「匯入種子 / 匯出備份」，會正常追蹤（DB 才是真相）。

# AI 模型設定（含真實金鑰）：只在本機，絕不進版控
src/ZonWiki.Api/ai-models.json
ai-models.json

# TTS 音檔快取、DataProtection 金鑰等 runtime 資料（不進版控）
src/ZonWiki.Api/App_Data/

# dotnet test 輸出重導目錄（避 exe 鎖時用）與前端測試產物截圖：皆建置/測試產物，不進版控
artifacts/
frontend/test-artifacts/
